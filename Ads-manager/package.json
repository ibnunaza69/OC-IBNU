{
  "name": "meta-ads-dev",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal Meta Ads operations platform scaffold",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "npm run build:dashboard && tsc -p tsconfig.build.json",
    "build:dashboard": "node scripts/build-dashboard.mjs",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke:dashboard": "playwright test --config=playwright.config.ts",
    "test:smoke:dashboard:install-browser": "playwright install chromium",
    "dashboard:hash-password": "node scripts/generate-dashboard-password-hash.mjs",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.47.0",
    "@vue-flow/minimap": "^1.5.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.6.1",
    "lucide-vue-next": "^1.0.0",
    "pg": "^8.16.3",
    "pg-boss": "^10.3.3",
    "pino": "^9.9.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.22",
    "vue-router": "^5.0.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "nuxt": "^4.3.0",
    "@iconify-json/lucide": "^1.2.101",
    "@playwright/test": "^1.56.0",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "drizzle-kit": "^0.31.5",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
