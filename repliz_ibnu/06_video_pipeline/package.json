{
  "name": "repliz-video-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remotion studio",
    "render:sample": "node scripts/render-sample.mjs",
    "render:quote": "npx remotion render src/index.ts QuotePromoVertical out/quote-promo-sample.mp4 --props=examples/props/quote-promo.json",
    "render:carousel": "npx remotion render src/index.ts CarouselTeaserVertical out/carousel-teaser-sample.mp4 --props=examples/props/carousel-teaser.json",
    "props:sample": "node scripts/make-props.mjs examples/briefs/canva-animasi.json examples/props/canva-animasi.json",
    "quick:quote": "node scripts/generate-quick-render.mjs examples/briefs/quick-quote-brief.json examples/props/generated-quote.json",
    "quick:carousel": "node scripts/generate-quick-render.mjs examples/briefs/quick-carousel-brief.json examples/props/generated-carousel.json",
    "lint:config": "node scripts/validate-env.mjs"
  },
  "dependencies": {
    "@remotion/cli": "4.0.340",
    "@remotion/google-fonts": "4.0.340",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.340",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
