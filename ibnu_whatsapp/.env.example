# Copy this file to .env and fill in values

# Server
PORT=8080
NODE_ENV=development

# Session storage directory
SESSION_DIR=./sessions

# Default account ID for single-account mode / fallback routes
DEFAULT_ACCOUNT_ID=default

# WhatsApp pairing number for first login (digits only, country code included)
WA_PAIRING_NUMBER=6281234567890

# API Keys (comma-separated)
API_KEYS=dev-key-123

# Webhook (optional, for inbound)
WEBHOOK_URL=http://localhost:3000/webhook
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=webhook-secret-change-me

# Rate limiting (messages per minute per account)
RATE_LIMIT_PER_ACCOUNT=20

# Logging
LOG_LEVEL=info

# Admin/API notes
# - Admin overview: GET /admin/overview
# - Contracts: GET /admin/contracts
